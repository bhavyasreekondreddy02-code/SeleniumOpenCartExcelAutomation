<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Master suite --> 
<suite name="MasterSuite">
<listeners>
   <listener class-name = "utilities.ExtentReportManager"/>
</listeners>
 <test thread-count="5" name="Test">
  <parameter name="os" value="Linux"></parameter> 
  <parameter name="browser" value="firefox"></parameter>
  <!-- we can run multiple browser tests in parallel by using testng.xml file -->
    <classes>
      <class name="testcase.TC001_AccountRegistrationTest"/> 
      <class name="testcase.TC002_LoginTest"/> 
   <!--  <class name="testcase.TC003_Datadriventest"/>-->
    </classes>
  </test>
  <test name="edgeTest">
  
  <parameter name="os" value="linux"></parameter>
  <parameter name="browser" value="edge"></parameter>
  
  <!-- we can run multiple browser tests in parallel by using testng.xml file -->
    <classes>
      <class name="testcase.TC001_AccountRegistrationTest"/> 
      <class name="testcase.TC002_LoginTest"/> 
    </classes>
  </test> <!-- Test -->
   <test name="chromeTest">
  
  <parameter name="os" value="linux"></parameter>
  <parameter name="browser" value="chrome"></parameter>
  
  <!-- we can run multiple browser tests in parallel by using testng.xml file -->
    <classes>
      <class name="testcase.TC001_AccountRegistrationTest"/> 
      <class name="testcase.TC002_LoginTest"/> 
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
